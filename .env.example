# ============================================
# 大模型 API 配置
# 填入你的 API Key 后，对应模型即可使用
# 未填写的模型会自动跳过
# ============================================

# DeepSeek (推荐，便宜好用)
DEEPSEEK_API_KEY=

# 通义千问 (DashScope) — 可选
DASHSCOPE_API_KEY=

# ChatGPT / OpenAI — 可选
OPENAI_API_KEY=

# 文心一言 (百度智能云) — 可选
ERNIE_API_KEY=
ERNIE_SECRET_KEY=

# 讯飞星火 — 可选
SPARK_API_KEY=

# ChatGLM (智谱AI) — 可选
ZHIPU_API_KEY=

# ============================================
# RabbitMQ 消息队列配置
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================
# 数据库配置
# ============================================
USE_SQLITE=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=email_classifier
