# ============================================
# 大模型 API 配置
# 填入你的 API Key 后，对应模型即可使用
# 未填写的模型会自动跳过
# ============================================

# DeepSeek (推荐，便宜好用)
DEEPSEEK_API_KEY=

# 通义千问 (DashScope) — 可选
DASHSCOPE_API_KEY=

# ChatGPT / OpenAI — 可选
OPENAI_API_KEY=

# 文心一言 (百度智能云) — 可选
ERNIE_API_KEY=
ERNIE_SECRET_KEY=

# 讯飞星火 — 可选
SPARK_API_KEY=

# ChatGLM (智谱AI) — 可选
ZHIPU_API_KEY=

# Ollama (本地模型) — 自动检测，无需配置
# OLLAMA_MODEL=gpt-oss:120b-cloud

# ============================================
# 安全配置
# ============================================
SECRET_KEY=change-me-to-a-random-string
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
RATE_LIMIT_PER_MINUTE=60
SESSION_TIMEOUT=3600

# ============================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
# ============================================
LOG_LEVEL=INFO

# ============================================
# RabbitMQ 消息队列配置
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ============================================
# 数据库配置
# ============================================
USE_SQLITE=true
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=mail_system
DB_POOL_SIZE=10

# ============================================
# Acceptor 节点配置 (可选覆盖)
# ============================================
# ACCEPTOR_1_URL=http://127.0.0.1:8503
# ACCEPTOR_2_URL=http://127.0.0.1:8504
# ACCEPTOR_3_URL=http://127.0.0.1:8505
# ACCEPTOR_4_URL=http://127.0.0.1:8506
